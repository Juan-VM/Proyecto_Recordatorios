@model List<Asignacion_2_Recordatorios.Models.Recordatorio>

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Mis Recordatorios</h2>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            + Nuevo Recordatorio
        </a>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>Título</th>
                            <th>Descripción</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Situación</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            string situacion = "";

                            if (item.Completado)
                            {
                                situacion = "Finalizado";
                            }
                            else if (item.FechaRecordatorio < DateTime.Now)
                            {
                                situacion = "Vencido";
                            }
                            else if (item.FechaRecordatorio.Date == DateTime.Today)
                            {
                                situacion = "Hoy";
                            }
                            else
                            {
                                situacion = "Próximo";
                            }

                            string badgeClass = situacion switch
                            {
                                "Finalizado" => "bg-success",
                                "Vencido" => "bg-danger",
                                "Hoy" => "bg-warning text-dark",
                                _ => "bg-info"
                            };

                            <tr>

                                <td class="fw-semibold">@item.Titulo</td>

                                <td class="text-muted">@item.Descripcion</td>

                                <td>
                                    @item.FechaRecordatorio.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td>
                                    @if (item.Completado)
                                    {
                                        <span class="badge bg-success">Completado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pendiente</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge @badgeClass">
                                        @situacion
                                    </span>
                                </td>

                                <td class="text-center">

                                    @if (!item.Completado)
                                    {
                                        <a asp-action="Completar"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-success">
                                            ✔ Completar
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Sin acciones</span>
                                    }

                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>