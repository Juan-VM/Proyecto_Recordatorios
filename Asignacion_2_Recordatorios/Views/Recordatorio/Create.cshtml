@model Asignacion_2_Recordatorios.Models.Recordatorio

<div class="container mt-4">

    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-bold">Nuevo Recordatorio</h2>
        <p class="text-muted mb-0">Crea un nuevo recordatorio para no olvidar tus tareas.</p>
    </div>

    <!-- Card Form -->
    <div class="card shadow-sm">
        <div class="card-body p-4">

            <form asp-action="Create">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Título</label>
                    <input asp-for="Titulo"
                           class="form-control"
                           placeholder="Ej: Comprar materiales..." />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Descripción</label>
                    <textarea asp-for="Descripcion"
                              class="form-control"
                              rows="3"
                              placeholder="Detalles del recordatorio..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Fecha y Hora</label>
                    <input asp-for="FechaRecordatorio"
                           type="datetime-local"
                           class="form-control" />
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-primary shadow-sm">
                        Guardar
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>