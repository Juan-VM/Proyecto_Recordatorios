@model List<Asignacion_2_Recordatorios.Models.RecordatorioVista>

<table class="table table-hover align-middle mb-0">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Descripción</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Situación</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            string badgeClass = item.Situacion switch
            {
                "Completado" => "bg-success",
                "Vencido" => "bg-danger",
                "Hoy" => "bg-warning text-dark",
                _ => "bg-info"
            };
            <tr>
                <td>@item.Id</td>
                <td class="fw-semibold">
                    @item.Titulo
                </td>
                <td class="text-muted">
                    @item.Descripcion
                </td>
                <td>
                    @item.FechaRecordatorio.ToString("dd/MM/yyyy HH:mm")
                </td>
                <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">
                            Completado
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            Pendiente
                        </span>
                    }
                </td>
                <td>
                    <span class="badge @badgeClass">
                        @item.Situacion
                    </span>
                </td>

                <td class="text-center">
                    @if (!item.Estado)
                    {
                        <a asp-action="Completar"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-success">
                            ✔ Completar
                        </a>
                    }
                    else
                    {
                        <span class="text-muted small">
                            Sin acciones
                        </span>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>